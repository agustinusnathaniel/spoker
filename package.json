{
  "name": "spoker",
  "version": "1.17.2",
  "private": true,
  "author": "agustinusnathaniel",
  "engines": {
    "node": "^24.11.x"
  },
  "packageManager": "pnpm@10.24.0",
  "pnpm": {
    "neverBuiltDependencies": [],
    "overrides": {
      "@types/react": "19.2.14"
    }
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "turbo": "pnpm dlx turbo@2.6.3",
    "build:turbo": "pnpm turbo build",
    "postbuild": "next-sitemap --config next-sitemap.config.js",
    "start": "next start",
    "type:check": "tsc --noEmit",
    "ultracite:check": "ultracite check",
    "ultracite:fix": "ultracite fix",
    "check:turbo": "pnpm turbo ultracite:check type:check",
    "check:unused": "knip",
    "release": "cross-env HUSKY=0 standard-version",
    "push-release": "git push --follow-tags origin dev",
    "up-interactive": "pnpm up -i",
    "up-latest": "pnpm up-interactive -L",
    "generate-rules": "ts-node tools/generate-rules.ts",
    "contributors:add": "all-contributors add",
    "contributors:generate": "all-contributors generate",
    "prepare": "husky install"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.34.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "^11",
    "@fontsource/gabarito": "^5.2.8",
    "@fontsource/gantari": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "@sentry/nextjs": "^10.45.0",
    "firebase": "^12.11.0",
    "lodash-es": "^4.17.23",
    "nanoid": "^5.1.7",
    "next": "16.2.1",
    "next-seo": "^7.2.0",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-fast-compare": "^3.2.2",
    "react-hook-form": "^7.72.0",
    "react-icons": "^5.6.0",
    "react-rewards": "^2.1.0",
    "react-textarea-autosize": "^8.5.9",
    "twemoji": "14.0.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@commitlint/config-conventional": "^20.4.4",
    "@commitlint/cz-commitlint": "^20.4.4",
    "@commitlint/types": "^20.4.4",
    "@eslint/eslintrc": "^3.3.5",
    "@jahed/firebase-rules": "^2.1.1",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.5.0",
    "@types/react": "19.2.14",
    "all-contributors-cli": "^6.26.1",
    "commitizen": "^4.3.1",
    "commitlint": "^20.4.4",
    "cross-env": "^10.1.0",
    "husky": "^9.1.7",
    "knip": "^6.0.0",
    "lint-staged": "^16.3.4",
    "next-sitemap": "^4.2.3",
    "standard-version": "^9.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "ultracite": "7.4.2"
  },
  "repository": {
    "url": "https://github.com/agustinusnathaniel/spoker"
  },
  "nextBundleAnalysis": {
    "budget": null,
    "budgetPercentIncreaseRed": 20,
    "showDetails": true
  }
}
